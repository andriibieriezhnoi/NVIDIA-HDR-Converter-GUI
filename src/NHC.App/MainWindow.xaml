<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NHC.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:NHC.App.Views"
        Title="NVIDIA HDR Converter">
    <Grid>
        <NavigationView x:Name="Nav"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="Nav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="convert" Content="Convert" Icon="OpenFile" />
                <NavigationViewItem Tag="batch" Content="Batch" Icon="AllApps" />
                <NavigationViewItem Tag="settings" Content="Settings" Icon="Setting" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
