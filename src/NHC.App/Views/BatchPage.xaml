<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="NHC.App.Views.BatchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:NHC.App.ViewModels">
    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Pick input folder" Command="{x:Bind ViewModel.PickInputFolderCommand}" />
            <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.InputFolder, Mode=OneWay}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Pick output folder" Command="{x:Bind ViewModel.PickOutputFolderCommand}" />
            <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.OutputFolder, Mode=OneWay}" />
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Items}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:BatchItem">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind FileName}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Stage, Mode=OneWay}" Opacity="0.7" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Spacing="8">
            <ProgressBar Value="{x:Bind ViewModel.Progress, Mode=OneWay}" Minimum="0" Maximum="1" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Opacity="0.8" />
                <Button Grid.Column="1"
                        Style="{ThemeResource AccentButtonStyle}"
                        Content="Run"
                        Command="{x:Bind ViewModel.RunCommand}" />
            </Grid>
        </StackPanel>
    </Grid>
</Page>
