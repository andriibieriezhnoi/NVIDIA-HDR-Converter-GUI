<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="NHC.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="24" Spacing="12">
        <TextBlock Text="Diagnostics" FontSize="20" FontWeight="SemiBold" />
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Active ORT provider:" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ActiveExecutionProvider, Mode=OneWay}" />
        </Grid>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="AI enhancement available:" />
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.EnhancementAvailable, Mode=OneWay}" />
        </Grid>
    </StackPanel>
</Page>
